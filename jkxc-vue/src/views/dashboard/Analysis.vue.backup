                suffix="家"
                :value-style="{ color: '#1890ff', fontSize: '28px' }"
              />
              <a-button type="link" @click="handleViewCustomers" style="padding: 0; margin-top: 8px">
                查看详情 <a-icon type="right" />
              </a-button>
            </a-card>
          </a-col>
          <a-col :span="6">
            <a-card :bordered="false">
              <a-statistic
