        <!-- 业务类型分布和业务员排名 -->
        <a-row :gutter="16" style="margin-bottom: 24px">
          <a-col :span="12">
            <a-card title="业务类型分布" :bordered="false">
              <div ref="businessTypeChart" style="width: 100%; height: 350px"></div>
            </a-card>
          </a-col>
          <a-col :span="12">
            <a-card title="业务员排名（Top 10）" :bordered="false">
