<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.system.mapper.SysAuditTaskCostMapper">

    <!-- 根据任务ID查询所有成本记录 -->
    <select id="getCostsByTaskId" resultType="org.jeecg.modules.system.entity.SysAuditTaskCost">
        SELECT * FROM sys_audit_task_cost
        WHERE task_id = #{taskId}
        ORDER BY sort_order ASC
    </select>

    <!-- 删除任务的所有成本记录 -->
    <delete id="deleteByTaskId">
        DELETE FROM sys_audit_task_cost
        WHERE task_id = #{taskId}
    </delete>

</mapper>

