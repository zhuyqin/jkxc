<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.order.mapper.GhAccountingHandoverMapper">

    <!-- 根据订单ID查询代账交接 -->
    <select id="getHandoverByOrderId" resultType="org.jeecg.modules.order.entity.GhAccountingHandover">
        SELECT * FROM gh_accounting_handover
        WHERE order_id = #{orderId}
        AND del_flag = 0
        LIMIT 1
    </select>

</mapper>

