<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.order.mapper.GhOrderExpenseMapper">

    <!-- 根据订单ID查询支出记录列表（包括待审核和已审核的记录） -->
    <select id="getExpensesByOrderId" resultType="org.jeecg.modules.order.entity.GhOrderExpense">
        SELECT * FROM gh_order_expense
        WHERE order_id = #{orderId}
        AND (del_flag = 0 OR del_flag IS NULL)
        ORDER BY expense_time DESC, create_time DESC
    </select>

</mapper>

