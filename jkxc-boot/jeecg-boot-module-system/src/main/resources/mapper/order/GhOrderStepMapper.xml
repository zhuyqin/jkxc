<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.jeecg.modules.order.mapper.GhOrderStepMapper">

    <!-- 根据订单ID查询步骤列表 -->
    <select id="getStepsByOrderId" resultType="org.jeecg.modules.order.entity.GhOrderStep">
        SELECT * FROM gh_order_step
        WHERE order_id = #{orderId}
        ORDER BY step_order ASC, create_time ASC
    </select>

</mapper>

